---
import CheckArrowIcon from '../assets/icons/CheckArrowIcon.astro';

const pricingData = [
  'Seamless integration',
  'Real-time data visualization',
  'Advanced predictive analytics',
  'Collaborative environment',
  'Responsive customer support',
];
---

<section class="bg-bgDark2 relative flex w-full justify-center">
  <div class="absolute -top-16" id="pricing"></div>
  <div class="content-container bg-bgDark2 pt-12 pb-20">
    <div class="fade-in">
      <div>
        <div class="mx-auto mb-16 max-w-2xl text-center">
          <span class="block-subtitle">Find Your Perfect Fit</span>
          <h2 class="font-heading text-primaryText mt-6 mb-6 text-4xl font-bold lg:text-5xl">
            Choose your best plan
          </h2>
          <p class="text-secondaryText mb-6">
            Select the plan that suits your needs and benefit from our analytics tools.
          </p>
          <label
            class="bg-bgDark3 group relative mx-auto flex h-12 w-44 cursor-pointer items-center justify-between rounded-lg pr-36 pl-1 text-xl"
          >
            <input
              type="checkbox"
              class="peer appearance-none"
              id="pricing-toggle"
              aria-label="Switch between monthly and yearly pricing"
            />
            <span
              class="bg-bgDark3 after:bg-primaryColor flex h-8 w-[5.5rem] cursor-pointer items-center pr-2 duration-300 ease-in-out after:h-10 after:w-[30rem] after:rounded-lg after:shadow-md after:duration-300 peer-checked:after:translate-x-[5.5rem]"
            ></span>
            <div class="text-primaryText absolute flex text-sm font-bold">
              <div class="mr-9 ml-3" id="monthly-label">Monthly</div>
              <div class="text-gray-400" id="yearly-label">Yearly</div>
            </div>
          </label>
        </div>
        <div class="-mx-4 mt-20 flex flex-col flex-wrap items-center lg:flex-row">
          <div
            class="mb-8 w-full max-w-[21.875rem] px-4 sm:max-w-[23.75rem] lg:mb-0 lg:w-1/3 lg:max-w-none"
          >
            <div class="card rounded-3xl p-8">
              <h3 class="font-heading text-primaryText mb-2 text-left text-xl font-bold">
                Beginner
              </h3>
              <div class="flex items-end justify-start">
                <div class="text-primaryText mt-4 mr-2 text-left text-4xl font-bold sm:text-5xl">
                  $0
                </div>
                <div class="price-period text-gray-500">/ month</div>
              </div>
              <p class="mt-4 mb-6 text-left leading-loose text-gray-500 2xl:mb-10">
                The perfect way to get started and get used to our tools.
              </p>
              <ul class="text-primaryText mb-2 2xl:mb-6">
                {
                  pricingData.map((text) => (
                    <li class="mb-4 flex text-sm 2xl:text-base">
                      <>
                        <CheckArrowIcon />
                        <span>{text}</span>
                      </>
                    </li>
                  ))
                }
              </ul>
              <button
                class="contained-button mt-16 inline-block w-full rounded-xl rounded-t-xl px-4 py-2 text-center leading-loose font-bold"
                data-open-modal
                aria-label="Get started with Beginner plan"
              >
                Get Started
              </button>
            </div>
          </div>
          <div
            class="mb-8 w-full max-w-[21.875rem] px-4 sm:max-w-[23.75rem] lg:mb-0 lg:w-1/3 lg:max-w-none"
          >
            <div class="card rounded-3xl px-8 py-8">
              <h3 class="font-heading text-primaryText mb-2 text-left text-2xl font-bold 2xl:mb-4">
                Standard
              </h3>
              <div class="flex items-end justify-start">
                <div
                  class="text-primaryText price-amount mt-4 mr-2 text-left text-4xl font-bold sm:text-5xl"
                  role="status"
                  aria-live="polite"
                  data-monthly="$19"
                  data-yearly="$180"
                >
                  $19
                </div>
                <div class="price-period text-gray-500">/ month</div>
              </div>
              <p class="mt-8 mb-8 text-left leading-loose text-gray-500 2xl:mb-12">
                Unlock more features and elevate your data analysis.
              </p>
              <ul class="text-primaryText mb-14">
                {
                  pricingData.map((text) => (
                    <li class="mb-4 flex text-sm 2xl:text-base">
                      <>
                        <CheckArrowIcon />
                        <span>{text}</span>
                      </>
                    </li>
                  ))
                }
              </ul>
              <button
                class="contained-button mt-20 inline-block w-full px-4 py-2 text-center leading-loose transition duration-200"
                data-open-modal
                aria-label="Get started with Standard plan"
              >
                Get Started
              </button>
            </div>
          </div>
          <div
            class="mb-8 w-full max-w-[21.875rem] px-4 sm:max-w-[23.75rem] lg:mb-0 lg:w-1/3 lg:max-w-none"
          >
            <div class="card rounded-3xl p-8">
              <h3 class="font-heading text-primaryText mb-2 text-left text-xl font-bold">
                Premium
              </h3>
              <div class="flex items-end justify-start">
                <div
                  class="text-primaryText price-amount mt-4 mr-2 text-left text-4xl font-bold sm:text-5xl"
                  role="status"
                  aria-live="polite"
                  data-monthly="$36"
                  data-yearly="$390"
                >
                  $36
                </div>
                <div class="price-period text-gray-500">/ month</div>
              </div>
              <p class="mt-4 mb-6 text-left leading-loose text-gray-500 2xl:mb-10">
                Experience the full power of our analytic platform
              </p>
              <ul class="text-primaryText mb-2 2xl:mb-6">
                {
                  pricingData.map((text) => (
                    <li class="mb-4 flex text-sm 2xl:text-base">
                      <>
                        <CheckArrowIcon />
                        <span>{text}</span>
                      </>
                    </li>
                  ))
                }
              </ul>
              <button
                class="contained-button mt-16 inline-block w-full rounded-xl rounded-t-xl px-4 py-2 text-center leading-loose font-bold"
                data-open-modal
                aria-label="Get started with Premium plan"
              >
                Get Started
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById('pricing-toggle') as HTMLInputElement;
  const monthlyLabel = document.getElementById('monthly-label');
  const yearlyLabel = document.getElementById('yearly-label');
  const amounts = document.querySelectorAll('.price-amount');
  const periods = document.querySelectorAll('.price-period');

  toggle?.addEventListener('change', () => {
    const isYearly = toggle.checked;

    monthlyLabel?.classList.toggle('text-gray-400', isYearly);
    yearlyLabel?.classList.toggle('text-gray-400', !isYearly);

    amounts.forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = isYearly ? htmlEl.dataset.yearly! : htmlEl.dataset.monthly!;
    });

    periods.forEach((el) => {
      el.textContent = isYearly ? '/ year' : '/ month';
    });
  });
</script>
