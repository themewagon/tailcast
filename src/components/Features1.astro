---
import { Image } from 'astro:assets';
import feature1 from '../assets/images/feature1.jpg';
import feature2 from '../assets/images/feature2.jpg';
import feature3 from '../assets/images/feature3.jpg';
import feature4 from '../assets/images/feature4.jpg';
import CheckArrowIcon from '../assets/icons/CheckArrowIcon.astro';
---

<section
  class="bg-bgDark2 -mt-8 mb-8 w-full pt-24 sm:-mt-8 sm:mb-24 md:pt-[12vw] lg:pt-16 xl:-mt-8 2xl:mt-0"
  id="features"
>
  <div class="fade-in">
    <div
      class="mx-auto flex w-11/12 flex-wrap items-center md:pl-4 xl:w-[81.25rem] xl:pr-16 xl:pl-16 2xl:w-[90.625rem]"
    >
      <div class="mb-12 w-full lg:mb-0 lg:w-1/2">
        <div class="lg:w-unset mx-auto w-11/12 sm:w-4/5 md:w-3/4 lg:mx-auto">
          <span class="block-subtitle">Embrace Innovation</span>
          <h2 class="block-big-title mt-6 mb-8 text-4xl lg:text-5xl">
            Unlike any tool you used before
          </h2>
          <p class="text-secondaryText mb-10 leading-loose">
            Discover a new level of data analysis with our innovative and user-friendly platform.
            Transform your business needs with actionable insights.
          </p>
          <ul class="text-primaryText mb-6">
            <li class="mb-4 flex"><CheckArrowIcon /><span>Real-time data visualization</span></li>
            <li class="mb-4 flex"><CheckArrowIcon /><span>Advanced predictive analytics</span></li>
            <li class="mb-4 flex"><CheckArrowIcon /><span>Seamless integration with APIs</span></li>
          </ul>
        </div>
      </div>
      <div
        class="mx-auto flex w-3/4 flex-wrap justify-center sm:pr-8 lg:-mx-4 lg:w-1/2 lg:pt-10 lg:pl-4 xl:px-8"
      >
        <div class="mb-8 w-full px-2 sm:w-1/2 lg:mb-0 lg:px-0">
          <div class="mb-4 rounded py-3 pr-2 pl-3">
            <div class="relative">
              <Image
                src={feature1}
                alt="Feature image 1"
                class="sm:mx-unset image-border mx-auto rounded-xl"
                loading="eager"
                decoding="sync"
              />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
          <div class="rounded py-3 pr-2 pl-3">
            <div class="relative">
              <Image
                src={feature2}
                alt="Feature image 2"
                class="sm:mx-unset image-border mx-auto rounded-xl"
                loading="eager"
                decoding="sync"
              />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
        </div>
        <div class="hidden w-1/2 px-2 pt-12 sm:inline-block lg:mt-20 lg:pt-0">
          <div class="mb-4 rounded-lg py-3 pr-2 pl-3">
            <div class="relative">
              <Image
                src={feature3}
                alt="Feature image 3"
                class="image-border rounded-xl"
                loading="eager"
                decoding="sync"
              />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
          <div class="rounded-lg py-3 pr-2 pl-3">
            <div class="relative">
              <Image
                src={feature4}
                alt="Feature image 4"
                class="image-border rounded-xl"
                loading="eager"
                decoding="sync"
              />
              <div class="pointer-events-none absolute inset-0 rounded-xl bg-black/10"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
