---
/**
 * Testimonials - Infinite horizontal marquee
 * Two rows scrolling in opposite directions, continuous loop.
 */
import { Image } from 'astro:assets';
import testimonial1 from '../assets/images/testimonial1.png';
import testimonial2 from '../assets/images/testimonial2.png';
import testimonial3 from '../assets/images/testimonial3.png';

const row1 = [
  {
    name: 'John Watkins',
    title: 'Founder of Dashflow',
    content:
      'The powerful analytic tools have helped us streamline our processes and make data-driven decisions that positively impact our efficiency.',
    image: testimonial1,
    rating: 5,
  },
  {
    name: 'Sarah Chen',
    title: 'CTO at Moonrise',
    content:
      'We switched to Tailcast from a legacy analytics suite and the difference was night and day. The dashboard is intuitive and lightning fast.',
    image: testimonial2,
    rating: 5,
  },
  {
    name: 'Mark Rodriguez',
    title: 'Head of Product at Vortex',
    content:
      'What sets Tailcast apart is its ability to turn complex datasets into clear, actionable insights. Our product team uses it daily.',
    image: testimonial3,
    rating: 5,
  },
  {
    name: 'Elena Vasquez',
    title: 'Lead Engineer at Prism',
    content:
      'Onboarding was seamless. Our non-technical team members were creating their own dashboards within the first week. Unheard of in this space.',
    image: testimonial1,
    rating: 5,
  },
  {
    name: 'David Park',
    title: 'CEO at NovaTech',
    content:
      'We cut our reporting time by 80%. What used to take a full day now happens automatically before the morning standup.',
    image: testimonial2,
    rating: 5,
  },
];

const row2 = [
  {
    name: 'Olivia Grant',
    title: 'Data Lead at Helix',
    content:
      "Finally an analytics tool that doesn't feel like it was designed in 2010. Dark mode, fast UI, and data that actually makes sense to the whole team.",
    image: testimonial3,
    rating: 5,
  },
  {
    name: 'James Thornton',
    title: 'PM at NexaFlow',
    content:
      'The API is beautifully designed. We integrated Tailcast into our CI/CD pipeline in under an hour. That never happens with analytics tools.',
    image: testimonial1,
    rating: 5,
  },
  {
    name: 'Amara Osei',
    title: 'VP Engineering at Arcline',
    content:
      'Tailcast handles billions of events without breaking a sweat. Our real-time dashboards have never been faster, even at 10x our original scale.',
    image: testimonial2,
    rating: 5,
  },
  {
    name: 'Ryan Mitchell',
    title: 'CTO at Streamline',
    content:
      'The custom reporting alone justified the switch. We went from spending hours in spreadsheets to having everything automated and beautifully presented.',
    image: testimonial3,
    rating: 5,
  },
  {
    name: 'Sofia Kim',
    title: 'Head of Growth at Prism',
    content:
      "I've evaluated dozens of analytics platforms. Tailcast is the only one where our entire team - engineers and non-engineers - actually enjoys using it.",
    image: testimonial1,
    rating: 5,
  },
];
---

<section class="bg-bgDark2 w-full overflow-hidden pt-8 pb-8 lg:pt-16 lg:pb-12">
  <div class="fade-in">
    <div class="block-subtitle mb-6 text-center">Testimonials</div>
    <div class="block-big-title mb-16 px-8 text-center sm:px-24 md:px-48">
      Loved by thousands of users
    </div>

    <!-- Row 1 - scrolls left -->
    <div class="marquee-container mb-6">
      <div class="marquee-track marquee-left">
        {
          [...row1, ...row1].map((t, i) => (
            <div
              class="marquee-card group card"
              {...(i >= row1.length ? { 'aria-hidden': 'true' } : {})}
            >
              <div class="mb-4 flex gap-0.5" role="img" aria-label={`${t.rating} out of 5 stars`}>
                {Array.from({ length: t.rating }).map(() => (
                  <svg
                    class="text-secondaryColor fill-secondaryColor h-4 w-4"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                  </svg>
                ))}
              </div>
              <p class="text-primaryText mb-6 text-[0.95rem] leading-relaxed">"{t.content}"</p>
              <div class="mt-auto flex items-center gap-3">
                <Image
                  src={t.image}
                  alt={t.name}
                  width={40}
                  height={40}
                  class="ring-mainBorderDarker rounded-full ring-1"
                  loading="eager"
                  decoding="sync"
                />
                <div>
                  <div class="text-primaryText text-sm font-semibold">{t.name}</div>
                  <div class="text-secondaryText text-xs">{t.title}</div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Row 2 - scrolls right -->
    <div class="marquee-container">
      <div class="marquee-track marquee-right">
        {
          [...row2, ...row2].map((t, i) => (
            <div
              class="marquee-card group card"
              {...(i >= row2.length ? { 'aria-hidden': 'true' } : {})}
            >
              <div class="mb-4 flex gap-0.5" role="img" aria-label={`${t.rating} out of 5 stars`}>
                {Array.from({ length: t.rating }).map(() => (
                  <svg
                    class="text-secondaryColor fill-secondaryColor h-4 w-4"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                  </svg>
                ))}
              </div>
              <p class="text-primaryText mb-6 text-[0.95rem] leading-relaxed">"{t.content}"</p>
              <div class="mt-auto flex items-center gap-3">
                <Image
                  src={t.image}
                  alt={t.name}
                  width={40}
                  height={40}
                  class="ring-mainBorderDarker rounded-full ring-1"
                  loading="eager"
                  decoding="sync"
                />
                <div>
                  <div class="text-primaryText text-sm font-semibold">{t.name}</div>
                  <div class="text-secondaryText text-xs">{t.title}</div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Fade edges -->
    <style>
      .marquee-container {
        position: relative;
        width: 100%;
      }
      .marquee-container::before,
      .marquee-container::after {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 120px;
        z-index: 10;
        pointer-events: none;
      }
      .marquee-container::before {
        left: 0;
        background: linear-gradient(to right, rgb(30, 31, 35) 0%, transparent 100%);
      }
      .marquee-container::after {
        right: 0;
        background: linear-gradient(to left, rgb(30, 31, 35) 0%, transparent 100%);
      }

      .marquee-track {
        display: flex;
        gap: 1.5rem;
        width: max-content;
      }

      .marquee-left {
        animation: marqueeLeft 60s linear infinite;
      }
      .marquee-right {
        animation: marqueeRight 60s linear infinite;
      }

      .marquee-container:hover .marquee-track {
        animation-play-state: paused;
      }

      @keyframes marqueeLeft {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      @keyframes marqueeRight {
        0% {
          transform: translateX(-50%);
        }
        100% {
          transform: translateX(0);
        }
      }

      .marquee-card {
        flex-shrink: 0;
        width: 360px;
        padding: 1.5rem;
        border-radius: 1.25rem;
        display: flex;
        flex-direction: column;
        transition:
          border-color 0.5s ease,
          background-color 0.5s ease;
      }
    </style>
  </div>
</section>
