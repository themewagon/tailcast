---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredPost = posts[0];
const sidebarPosts = posts.slice(1, 4);
const allPosts = posts.slice(0, 4);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<section class="bg-bgDark2 relative mt-20 flex w-full justify-center">
  <div class="absolute -top-16" id="blog"></div>
  <div class="content-container bg-bgDark2 pt-4 pb-0">
    <div class="fade-in">
      <div class="mb-20">
        <div class="mx-auto mb-16 max-w-2xl text-center lg:mr-0 lg:ml-0 lg:text-left">
          <span class="block-subtitle">Our Blog</span>
          <h2 class="font-heading text-primaryText mt-6 mb-6 text-4xl font-bold lg:text-5xl">
            Latest Insights
          </h2>
          <p class="text-secondaryText mb-6">
            Stay updated with the latest trends and insights in our industry.
          </p>
        </div>

        <!-- Desktop layout (lg+): featured + sidebar -->
        <div class="hidden h-auto flex-row gap-8 lg:flex lg:h-[28rem] xl:h-[32rem]">
          <!-- Featured post (left) -->
          <a href={`/tailcast/blog/${featuredPost.id}`} class="group h-full lg:w-3/5">
            <article class="card flex h-full flex-col overflow-hidden rounded-3xl transition">
              <div class="flex-grow p-4 pb-0">
                <div class="bg-bgDark1Lighter flex h-full items-center justify-center rounded-2xl">
                  <svg
                    class="text-secondaryColor/30 h-32 w-32"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="0.5"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    set:html={featuredPost.data.icon}
                  />
                </div>
              </div>
              <div class="px-8 pt-5 pb-5">
                <div class="text-secondaryText mb-1 text-sm">
                  {formatDate(featuredPost.data.date)}
                </div>
                <h3
                  class="text-primaryText text-2xl font-bold transition group-hover:text-[#c8c9f8]"
                >
                  {featuredPost.data.title}
                </h3>
                <p class="text-secondaryText mt-2 text-sm leading-relaxed">
                  {featuredPost.data.subtitle}
                </p>
              </div>
            </article>
          </a>

          <!-- Sidebar posts (right) -->
          <div class="flex h-full flex-col gap-5 lg:w-2/5">
            {
              sidebarPosts.map((post) => (
                <a
                  href={`/tailcast/blog/${post.id}`}
                  class="group card flex flex-1 items-center gap-4 p-4 transition"
                >
                  <div class="bg-bgDark1Lighter flex aspect-square shrink-0 items-center justify-center self-stretch rounded-xl">
                    <svg
                      class="text-secondaryColor/40 h-8 w-8"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      set:html={post.data.icon}
                    />
                  </div>
                  <div>
                    <h3 class="text-primaryText blog-sidebar-title leading-snug font-bold transition group-hover:text-[#c8c9f8]">
                      {post.data.title}
                    </h3>
                    <div class="text-secondaryText mt-3 text-sm">{formatDate(post.data.date)}</div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Mobile/Tablet layout (< lg): 4 equal cards -->
        <div class="xs:grid-cols-2 grid grid-cols-1 gap-6 lg:hidden">
          {
            allPosts.map((post) => (
              <a href={`/tailcast/blog/${post.id}`} class="group">
                <article class="card flex h-full flex-col overflow-hidden rounded-2xl transition">
                  <div class="p-3 pb-0">
                    <div class="bg-bgDark1Lighter xs:aspect-auto xs:h-40 flex aspect-[16/9] items-center justify-center rounded-xl">
                      <svg
                        class="text-secondaryColor/30 h-16 w-16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="0.8"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                        set:html={post.data.icon}
                      />
                    </div>
                  </div>
                  <div class="px-5 pt-4 pb-4">
                    <div class="text-secondaryText mb-1 text-sm">{formatDate(post.data.date)}</div>
                    <h3 class="text-primaryText text-lg leading-snug font-bold transition group-hover:text-[#c8c9f8]">
                      {post.data.title}
                    </h3>
                  </div>
                </article>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
