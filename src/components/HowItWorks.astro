---
const process = [
  {
    step: '01',
    title: 'Connect your data',
    description:
      'Install our lightweight SDK or use the REST API. Most teams are sending events within 15 minutes.',
  },
  {
    step: '02',
    title: 'Build your views',
    description:
      'Use pre-built templates or create custom dashboards. Drag and drop metrics, set filters, choose visualizations.',
  },
  {
    step: '03',
    title: 'Get insights automatically',
    description:
      'Our AI surfaces anomalies and trends before you notice them. Set alerts that actually matter.',
  },
  {
    step: '04',
    title: 'Scale with confidence',
    description:
      'From startup to enterprise - same platform, same speed. No re-architecture needed as your data grows.',
  },
];
---

<section class="pt-8 pb-32">
  <div class="content-container">
    <div class="fade-in">
      <div class="mb-20 text-center">
        <span class="block-subtitle mb-6 block">How it works</span>
        <h2 class="text-primaryText text-3xl font-bold tracking-tight lg:text-4xl">
          From zero to insights in minutes
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          process.map((item, i) => (
            <div class="group relative">
              {i < process.length - 1 && (
                <div class="bg-mainBorderDarker absolute top-10 right-[calc(-50%+2rem)] left-[calc(50%+2rem)] hidden h-px lg:block" />
              )}
              <div class="text-center">
                <div
                  class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full transition-all duration-500"
                  style="background: rgba(99,102,241,0.05); border: 1px solid rgba(99,102,241,0.1);"
                >
                  <span class="text-primaryColor text-2xl font-bold">{item.step}</span>
                </div>
                <h3 class="text-primaryText mb-3 text-lg font-bold">{item.title}</h3>
                <p class="text-secondaryText text-sm leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
