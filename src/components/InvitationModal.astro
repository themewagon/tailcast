---
import CheckArrowIcon from '../assets/icons/CheckArrowIcon.astro';
import CloseIcon from '../assets/icons/CloseIcon.astro';
import TailcastLogo from '../assets/logos/TailcastLogo.astro';
---

<dialog id="invitation-modal" class="modal-backdrop" aria-labelledby="modal-title">
  <div
    class="xs:w-[90vw] xs:h-auto xs:max-w-[25rem] xs:rounded-2xl xs:pt-8 bg-bgDarkTransparentLighter main-border-gray-darker xs:block relative flex h-screen w-screen flex-col justify-start overflow-hidden rounded-none px-6 pt-[11vh] pb-8 backdrop-blur-xl lg:w-[53.125rem] lg:max-w-none lg:px-10 lg:pt-8 xl:w-[57.5rem] 2xl:w-[68.75rem] 2xl:px-16 2xl:py-12"
  >
    <button class="modal-close-button" id="modal-close" aria-label="Close modal">
      <CloseIcon />
    </button>
    <div class="flex">
      <div class="hidden w-1/2 pl-4 lg:inline 2xl:pl-0">
        <h2 class="text-primaryText mt-6 mb-2 text-4xl font-bold tracking-normal 2xl:text-5xl">
          Subscribe Now
        </h2>
        <h2 class="text-secondaryColor text-4xl font-bold tracking-normal 2xl:text-5xl">
          Winter is coming
        </h2>
        <ul class="text-primaryText mt-8 mb-6 2xl:mt-12">
          <li class="mb-4 flex"><CheckArrowIcon /><span>Vestibulum viverra</span></li>
          <li class="mb-4 flex"><CheckArrowIcon /><span>Morbi mollis metus pretium</span></li>
          <li class="mb-4 flex"><CheckArrowIcon /><span>Etiam lectus nunc, commodo</span></li>
        </ul>
      </div>
      <div class="flex w-full flex-col items-center justify-center pt-0 lg:w-1/2">
        <div class="mb-6 flex items-center justify-start pr-6 lg:hidden">
          <div class="mr-2 text-8xl text-white">
            <TailcastLogo />
          </div>
          <div class="font-['Inter'] text-3xl font-bold text-white">Tailcast</div>
        </div>
        <h3
          class="text-primaryText mb-5 text-center text-xl leading-snug font-bold 2xl:mb-7 2xl:text-2xl"
          id="modal-title"
        >
          Join 3,953 other developers
        </h3>
        <div class="-m-2 mt-4 flex flex-wrap lg:mt-0">
          <div class="mx-auto w-full p-2 sm:w-4/5">
            <label for="modal-email" class="sr-only">Email address</label>
            <input
              class="form-input py-4 text-center font-medium"
              type="email"
              id="modal-email"
              placeholder="Your email address"
            />
          </div>
          <div class="mx-auto mt-4 w-full p-2 sm:w-4/5">
            <button
              class="text-primaryText shadow-4xl bg-primaryColor w-full cursor-pointer rounded-xl px-6 py-4 font-semibold transition duration-200 ease-in-out hover:bg-[#7274f3] focus:ring focus:ring-indigo-300"
              type="button"
              aria-label="Join now"
            >
              Join Now
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</dialog>

<script>
  const initModal = () => {
    const modal = document.getElementById('invitation-modal') as HTMLDialogElement;
    const closeBtn = document.getElementById('modal-close');
    let previouslyFocused: HTMLElement | null = null;

    document.querySelectorAll('[data-open-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        previouslyFocused = document.activeElement as HTMLElement;
        modal.showModal();
      });
    });

    closeBtn?.addEventListener('click', () => modal.close());

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    modal?.addEventListener('close', () => {
      previouslyFocused?.focus();
    });
  };

  document.addEventListener('astro:page-load', initModal);
</script>
