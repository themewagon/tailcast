---
import AmazonLogo from '../assets/logos/AmazonLogo.astro';
import DropboxLogo from '../assets/logos/DropboxLogo.astro';
import NetflixLogo from '../assets/logos/NetflixLogo.astro';
import SlackLogo from '../assets/logos/SlackLogo.astro';
import SpotifyLogo from '../assets/logos/SpotifyLogo.astro';
import StripeLogo from '../assets/logos/StripeLogo.astro';
---

<section class="bg-bgDark1 mb-8 w-full py-12 sm:py-24 lg:mt-16 lg:mb-16">
  <div class="fade-in">
    <div class="content-container">
      <div
        class="-mx-4 flex flex-col items-center justify-center text-center lg:flex-row lg:text-left"
      >
        <div class="mb-12 w-full px-4 lg:mb-0 lg:w-1/2">
          <div class="flex flex-col">
            <h2
              class="text-primaryText mb-2 text-4xl font-bold tracking-normal sm:text-5xl 2xl:text-6xl"
            >
              Trusted by brands
            </h2>
            <h2
              class="to-secondaryColor bg-gradient-to-r from-[rgb(130,132,244)] bg-clip-text text-4xl font-bold tracking-normal text-transparent sm:text-5xl 2xl:text-6xl"
            >
              all over the world
            </h2>
          </div>
        </div>
        <div class="mx-auto w-2/3 sm:w-[38.75rem] lg:mx-0 lg:w-1/2 lg:pl-10">
          <div class="-m-4 flex flex-wrap">
            <div class="flex w-1/2 justify-center py-6 sm:w-1/3"><AmazonLogo /></div>
            <div class="flex w-1/2 justify-center py-6 sm:w-1/3"><DropboxLogo /></div>
            <div class="flex w-1/2 justify-center py-6 sm:w-1/3"><NetflixLogo /></div>
            <div class="flex w-1/2 justify-center py-6 sm:w-1/3"><StripeLogo /></div>
            <div class="flex w-1/2 justify-center py-6 sm:w-1/3"><SpotifyLogo /></div>
            <div class="flex w-1/2 justify-center py-6 sm:w-1/3"><SlackLogo /></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
