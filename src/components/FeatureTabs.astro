---
const tabs = [
  {
    heading: 'Real-time analytics',
    description:
      'Monitor every event as it happens. Live dashboards update instantly, giving your team the confidence to act on data - not gut feelings.',
    icon: `<path d="M3 3v18h18"/><path d="M7 16l4-8 4 4 4-8"/>`,
    color: 'rgb(99, 102, 241)',
  },
  {
    heading: 'Custom dashboards',
    description:
      'Drag, drop, and build the exact view you need. From high-level KPIs to granular breakdowns, every dashboard is tailored to your workflow.',
    icon: `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>`,
    color: 'rgb(161, 163, 247)',
  },
  {
    heading: 'Seamless integrations',
    description:
      'Connect your existing stack in minutes. REST API, webhooks, and native plugins for Slack, Zapier, and 50+ other tools - no custom code required.',
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
    color: 'rgb(129, 140, 248)',
  },
];
---

<section class="bg-bgDark2 w-full py-16 lg:py-24">
  <div class="fade-in">
    <div class="content-container">
      <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-16">
        <!-- Left: tabs -->
        <div
          class="flex w-full flex-col gap-2 lg:w-1/2"
          role="tablist"
          aria-label="Feature details"
        >
          {
            tabs.map((tab, i) => (
              <button
                class:list={[
                  'feature-tab group relative cursor-pointer rounded-xl py-5 pr-6 pl-7 text-left transition-all duration-500',
                  i === 0 && 'is-active',
                ]}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`feature-panel-${i}`}
                id={`feature-tab-${i}`}
                data-tab-index={i}
                data-color={tab.color}
              >
                <div
                  class="feature-tab-bar absolute top-4 bottom-4 left-0 w-[3px] rounded-full transition-all duration-500"
                  style={`background-color: ${tab.color}`}
                />
                <div class="mb-2 flex items-center gap-3">
                  <div class="feature-tab-icon flex h-8 w-8 shrink-0 items-center justify-center rounded-lg transition-all duration-500">
                    <svg
                      class="h-4 w-4 transition-colors duration-500"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                      set:html={tab.icon}
                    />
                  </div>
                  <h3 class="text-primaryText text-lg font-bold tracking-tight transition-colors duration-500">
                    {tab.heading}
                  </h3>
                </div>
                <p class="feature-tab-desc text-secondaryText max-h-0 overflow-hidden pl-11 text-[0.9rem] leading-relaxed opacity-0 transition-all duration-500">
                  {tab.description}
                </p>
              </button>
            ))
          }
        </div>

        <!-- Right: image area -->
        <div class="w-full lg:w-1/2">
          <div
            class="feature-tab-image border-mainBorderDarker bg-bgDark1Lighter relative aspect-[4/3] w-full overflow-hidden rounded-2xl border"
          >
            <!-- Subtle grid pattern -->
            <div
              class="absolute inset-0 opacity-[0.03]"
              style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2240%22 height=%2240%22><line x1=%220%22 y1=%2240%22 x2=%2240%22 y2=%2240%22 stroke=%22white%22 stroke-width=%221%22/><line x1=%2240%22 y1=%220%22 x2=%2240%22 y2=%2240%22 stroke=%22white%22 stroke-width=%221%22/></svg>');"
            >
            </div>

            {
              tabs.map((tab, i) => (
                <div
                  class:list={[
                    'feature-tab-panel absolute inset-0 flex items-center justify-center transition-all duration-700',
                    i === 0
                      ? 'translate-y-0 opacity-100'
                      : 'pointer-events-none translate-y-4 opacity-0',
                  ]}
                  role="tabpanel"
                  id={`feature-panel-${i}`}
                  aria-labelledby={`feature-tab-${i}`}
                  data-panel-index={i}
                >
                  {/* Glow behind icon */}
                  <div
                    class="absolute h-48 w-48 rounded-full opacity-15 blur-3xl transition-opacity duration-700"
                    style={`background-color: ${tab.color}`}
                  />
                  {/* Icon circle */}
                  <div
                    class="relative flex h-32 w-32 items-center justify-center rounded-2xl border"
                    style={`border-color: ${tab.color}20; background-color: ${tab.color}08`}
                  >
                    <svg
                      class="h-14 w-14 transition-colors duration-500"
                      style={`color: ${tab.color}`}
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      viewBox="0 0 24 24"
                      set:html={tab.icon}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-tab {
    background: transparent;
  }
  .feature-tab .feature-tab-bar {
    opacity: 0;
    transform: scaleY(0.5);
  }
  .feature-tab .feature-tab-icon {
    background: rgb(255 255 255 / 0.05);
    color: rgb(174, 178, 183);
  }
  .feature-tab:hover .feature-tab-bar {
    opacity: 0.3;
    transform: scaleY(0.7);
  }
  .feature-tab:hover {
    background: rgb(255 255 255 / 0.02);
  }

  .feature-tab.is-active {
    background: rgb(255 255 255 / 0.03);
  }
  .feature-tab.is-active .feature-tab-bar {
    opacity: 1;
    transform: scaleY(1);
  }
  .feature-tab.is-active .feature-tab-icon {
    background: rgb(99 102 241 / 0.12);
    color: rgb(161, 163, 247);
  }
  .feature-tab.is-active .feature-tab-desc {
    max-height: 100px;
    opacity: 1;
    margin-top: 0.25rem;
  }
</style>

<script>
  const initFeatureTabs = () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.feature-tab');
    const panels = document.querySelectorAll<HTMLDivElement>('.feature-tab-panel');
    if (!tabs.length) return;

    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    const activate = (index: number) => {
      tabs.forEach((t) => {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      tabs[index].classList.add('is-active');
      tabs[index].setAttribute('aria-selected', 'true');

      panels.forEach((p) => {
        p.classList.remove('opacity-100', 'translate-y-0');
        p.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      });
      panels[index].classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      panels[index].classList.add('opacity-100', 'translate-y-0');

      current = index;
    };

    const startAutoplay = () => {
      clearInterval(interval);
      interval = setInterval(() => {
        activate((current + 1) % tabs.length);
      }, 4000);
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const idx = Number(tab.dataset.tabIndex);
        activate(idx);
        startAutoplay();
      });
    });

    startAutoplay();
  };

  document.addEventListener('astro:page-load', initFeatureTabs);
  document.addEventListener('DOMContentLoaded', initFeatureTabs);
</script>
