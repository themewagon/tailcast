---
const team = [
  {
    name: 'Alex Morgan',
    role: 'CEO & Co-founder',
    bio: 'Former product lead at Stripe. Passionate about making data accessible to every team, not just engineers.',
    icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
    linkedin: '#',
    twitter: '#',
  },
  {
    name: 'Sarah Chen',
    role: 'CTO & Co-founder',
    bio: 'Built distributed systems at Netflix. Obsessed with sub-100ms latency and clean APIs.',
    icon: `<polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/>`,
    linkedin: '#',
    twitter: '#',
  },
  {
    name: 'Marcus Rivera',
    role: 'Head of Design',
    bio: 'Previously at Figma. Believes the best analytics tool is one your whole team actually enjoys using.',
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
    linkedin: '#',
    twitter: '#',
  },
  {
    name: 'Emma Larsson',
    role: 'Head of Engineering',
    bio: 'Scaled infrastructure at Datadog. Leads the team that processes 2B+ events per month.',
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    linkedin: '#',
    twitter: '#',
  },
  {
    name: 'David Park',
    role: 'Lead Backend Engineer',
    bio: 'Formerly at Google Cloud. Architects the event pipeline that handles billions of data points.',
    icon: `<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>`,
    linkedin: '#',
    twitter: '#',
  },
  {
    name: 'Olivia Grant',
    role: 'Product Manager',
    bio: 'Led product at Amplitude before joining. Translates user pain points into features that ship fast.',
    icon: `<polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>`,
    linkedin: '#',
    twitter: '#',
  },
];
---

<section class="bg-bgDark2 w-full py-16 lg:py-24">
  <div class="fade-in">
    <div class="content-container">
      <div class="mb-14 text-center">
        <span class="block-subtitle mb-6 block">Our team</span>
        <h2 class="text-primaryText mb-4 text-3xl font-bold tracking-tight lg:text-4xl">
          The people behind Tailcast
        </h2>
        <p class="text-secondaryText mx-auto max-w-xl">
          A small, focused team building the analytics platform we always wished existed.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          team.map((member) => (
            <div class="group card hover:border-mainBorder overflow-hidden rounded-2xl transition-all duration-300">
              <div class="bg-bgDark1Lighter flex aspect-[4/3] w-full items-center justify-center">
                <svg
                  class="text-secondaryColor/20 group-hover:text-secondaryColor/35 h-14 w-14 transition-colors duration-500"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  viewBox="0 0 24 24"
                  set:html={member.icon}
                />
              </div>
              <div class="p-5">
                <h3 class="text-primaryText text-base font-bold">{member.name}</h3>
                <p class="text-secondaryColor mt-0.5 text-sm">{member.role}</p>
                <p class="text-secondaryText mt-3 text-[0.85rem] leading-relaxed">{member.bio}</p>
                <div class="mt-4 flex items-center gap-4">
                  <a
                    href={member.linkedin}
                    class="text-secondaryText hover:text-primaryText transition-colors duration-300"
                    aria-label={`${member.name} on LinkedIn`}
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                  </a>
                  <a
                    href={member.twitter}
                    class="text-secondaryText hover:text-primaryText transition-colors duration-300"
                    aria-label={`${member.name} on Twitter`}
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  </a>
                  <a
                    href="#"
                    class="text-secondaryText hover:text-primaryText transition-colors duration-300"
                    aria-label={`${member.name} on Dribbble`}
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 0C5.375 0 0 5.375 0 12s5.375 12 12 12 12-5.375 12-12S18.625 0 12 0zm7.938 5.563a10.18 10.18 0 0 1 2.312 6.375c-.337-.063-3.75-.75-7.187-.375-.063-.188-.125-.313-.188-.5-.187-.438-.375-.875-.625-1.313 3.813-1.562 5.5-3.75 5.688-4.187zM12 1.75c2.688 0 5.125 1.063 6.938 2.75-.125.375-1.688 2.438-5.375 3.813-1.688-3.063-3.563-5.563-3.813-5.938A10.448 10.448 0 0 1 12 1.75zM8 3.063c.25.313 2.063 2.875 3.813 5.875-4.813 1.25-9.063 1.25-9.5 1.25A10.29 10.29 0 0 1 8 3.063zM1.75 12v-.313c.438.013 5.375.063 10.5-1.437.313.563.563 1.125.813 1.688-.125.063-.313.063-.438.125-5.375 1.875-8.188 6.938-8.375 7.25A10.175 10.175 0 0 1 1.75 12zm3.938 8.063c.125-.188 2.188-4.688 7.938-6.875.063 0 .063 0 .125-.063a43.703 43.703 0 0 1 2.125 7.563 10.205 10.205 0 0 1-10.188-.625zm11.874-.688a42.59 42.59 0 0 0-1.938-7.188c3.25-.5 6.063.375 6.438.5a10.197 10.197 0 0 1-4.5 6.688z" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
