---
const { articleData } = Astro.props;
const { title, subtitle, date, image, author, readTime, tags } = articleData;
---

<div class="bg-bgDark2 pt-36 pb-20">
  <article class="fade-in content-container">
    <!-- Back link -->
    <a
      href="/blog"
      class="text-secondaryText hover:text-primaryText mb-10 inline-flex items-center gap-2 transition"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M19 12H5M5 12L12 19M5 12L12 5"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      Back to blog
    </a>

    <!-- Header -->
    <header class="mx-auto mb-12 max-w-4xl text-center">
      {
        tags && (
          <div class="mb-6 flex items-center justify-center gap-2">
            {tags.map((tag: string, index: number) => (
              <span
                class:list={[
                  'badge-primary whitespace-nowrap font-bold tracking-wider text-[#d4d5fa] uppercase',
                  index >= 2 && 'hidden sm:inline-flex',
                ]}
              >
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <h1 class="text-primaryText mb-6 text-3xl leading-tight font-bold sm:text-5xl lg:text-6xl">
        {title}
      </h1>
      <p class="text-secondaryText mb-8 text-lg">{subtitle}</p>
      <div class="text-secondaryText flex flex-col items-center justify-center gap-4 text-sm min-[560px]:flex-row">
        {
          author && (
            <div class="flex items-center gap-3">
              {author.avatar ? (
                <img
                  src={author.avatar}
                  alt={author.name}
                  class="h-10 w-10 rounded-full object-cover"
                  loading="eager"
                  decoding="sync"
                />
              ) : (
                <div class="bg-primaryColor text-primaryText flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold">
                  {author.name
                    .split(' ')
                    .map((n: string) => n[0])
                    .join('')}
                </div>
              )}
              <div class="text-left">
                <div class="text-primaryText font-medium">{author.name}</div>
                {author.role && <div class="text-secondaryText text-xs">{author.role}</div>}
              </div>
            </div>
          )
        }
        {author && <div class="bg-mainBorder hidden h-8 w-px min-[560px]:block" />}
        <div class="flex items-center gap-4">
          <div>{date}</div>
          {
            readTime && (
              <>
                <div class="bg-secondaryText h-1 w-1 rounded-full" />
                <div>{readTime}</div>
              </>
            )
          }
        </div>
      </div>
    </header>

    <!-- Hero image -->
    <div class="mx-auto mb-16 max-w-4xl">
      <img
        src={image}
        alt={title}
        class="aspect-[16/9] w-full rounded-2xl object-cover shadow-lg"
      />
    </div>

    <!-- Content -->
    <section
      class="article-content mx-auto max-w-3xl text-lg leading-9 text-[rgb(200,204,210)] sm:leading-10"
    >
      <slot />
    </section>

    <!-- Divider -->
    <div class="border-mainBorder mx-auto mt-16 mb-12 max-w-3xl border-t"></div>

    <!-- Footer / Share -->
    <div class="mx-auto flex max-w-3xl flex-col items-center justify-between gap-6 sm:flex-row">
      {
        author && (
          <div class="flex items-center gap-3">
            {author.avatar ? (
              <img
                src={author.avatar}
                alt={author.name}
                class="h-12 w-12 rounded-full object-cover"
                loading="eager"
                decoding="sync"
              />
            ) : (
              <div class="bg-primaryColor text-primaryText flex h-12 w-12 items-center justify-center rounded-full font-bold">
                {author.name
                  .split(' ')
                  .map((n: string) => n[0])
                  .join('')}
              </div>
            )}
            <div>
              <div class="text-primaryText font-bold">{author.name}</div>
              {author.role && <div class="text-secondaryText text-sm">{author.role}</div>}
            </div>
          </div>
        )
      }
      <div class="flex items-center gap-3">
        <span class="text-secondaryText text-sm">Share</span>
        <a
          href="#"
          class="bg-bgDark3 hover:bg-bgDark3Hover flex h-9 w-9 items-center justify-center rounded-lg transition"
          aria-label="Share on Twitter"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M22 4.01C21 4.5 20.02 4.69 19 5C17.89 3.86 16.02 3.78 14.82 4.83C13.62 5.88 13.28 7.61 14 9C10.56 9.16 7.34 7.53 5.22 4.79C4.08 6.75 4.67 9.24 6.5 10.5C5.74 10.48 5.01 10.27 4.36 9.89V9.94C4.36 11.98 5.77 13.73 7.74 14.14C7.03 14.34 6.29 14.37 5.56 14.24C6.12 16 7.72 17.2 9.56 17.23C8.03 18.44 6.14 19.1 4.19 19.09C3.79 19.09 3.39 19.07 3 19.02C4.97 20.3 7.26 20.99 9.61 20.97C17.02 20.97 21.08 14.41 21.08 8.68C21.08 8.49 21.08 8.31 21.07 8.12C22.01 7.44 22.82 6.58 23.44 5.58L22 4.01Z"
              fill="rgb(174, 178, 183)"></path>
          </svg>
        </a>
        <a
          href="#"
          class="bg-bgDark3 hover:bg-bgDark3Hover flex h-9 w-9 items-center justify-center rounded-lg transition"
          aria-label="Share on LinkedIn"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M16 8C17.5913 8 19.1174 8.63214 20.2426 9.75736C21.3679 10.8826 22 12.4087 22 14V21H18V14C18 13.4696 17.7893 12.9609 17.4142 12.5858C17.0391 12.2107 16.5304 12 16 12C15.4696 12 14.9609 12.2107 14.5858 12.5858C14.2107 12.9609 14 13.4696 14 14V21H10V14C10 12.4087 10.6321 10.8826 11.7574 9.75736C12.8826 8.63214 14.4087 8 16 8Z"
              fill="rgb(174, 178, 183)"></path>
            <rect x="2" y="9" width="4" height="12" fill="rgb(174, 178, 183)"></rect>
            <circle cx="4" cy="4" r="2" fill="rgb(174, 178, 183)"></circle>
          </svg>
        </a>
        <button
          class="bg-bgDark3 hover:bg-bgDark3Hover flex h-9 w-9 items-center justify-center rounded-lg transition"
          aria-label="Copy link"
          id="copy-link-btn"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M10 13C10.4295 13.5741 10.9774 14.0491 11.6066 14.3929C12.2357 14.7367 12.9315 14.9411 13.6467 14.9923C14.3618 15.0435 15.0796 14.9403 15.7513 14.6897C16.4231 14.4392 17.0331 14.047 17.54 13.54L20.54 10.54C21.4508 9.59695 21.9548 8.33394 21.9434 7.02296C21.932 5.71198 21.4061 4.45791 20.479 3.53087C19.552 2.60383 18.2979 2.07799 16.987 2.0666C15.676 2.0552 14.413 2.55918 13.47 3.47L11.75 5.18"
              stroke="rgb(174, 178, 183)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
            <path
              d="M14 11C13.5705 10.4259 13.0226 9.9508 12.3934 9.60704C11.7642 9.26328 11.0685 9.05886 10.3533 9.00765C9.63816 8.95643 8.92037 9.05963 8.24861 9.3102C7.57685 9.56077 6.96684 9.95296 6.45996 10.46L3.45996 13.46C2.54917 14.403 2.04519 15.666 2.05659 16.977C2.06798 18.288 2.59382 19.5421 3.52086 20.4691C4.4479 21.3961 5.70197 21.922 7.01295 21.9334C8.32393 21.9448 9.58694 21.4408 10.53 20.53L12.24 18.82"
              stroke="rgb(174, 178, 183)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </article>
</div>

<style>
  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }
  .article-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
  }
</style>
