---
import TailcastLogo from '../assets/logos/TailcastLogo.astro';
import GithubIcon from '../assets/icons/GithubIcon.astro';

const navbarLinks = [
  { label: 'Home', href: '/tailcast/#home' },
  { label: 'About', href: '/tailcast/about' },
  { label: 'Services', href: '/tailcast/services' },
  { label: 'Blog', href: '/tailcast/blog' },
  { label: 'Careers', href: '/tailcast/careers' },
  { label: 'Contact', href: '/tailcast/contact' },
];

const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/' || currentPath === '/index.html';

const isActive = (href: string) => {
  if (href.startsWith('/#')) return false;
  return currentPath.startsWith(href);
}
---

<nav
  class={`w-full h-20 flex flex-col justify-center items-center fixed z-40 transition-all duration-300 ${!isHomepage ? 'bg-bgDark1/70 backdrop-blur-[15px]' : ''}`}
  id="main-nav"
  data-homepage={isHomepage ? 'true' : 'false'}
  aria-label="Main navigation"
>
  <div class="relative flex w-11/12 items-center justify-between xl:w-10/12 2xl:w-7xl">
    <div>
      <a href="#home" aria-label="Home">
        <div class="flex grow basis-0 items-center justify-start">
          <div class="mr-2 text-6xl text-white">
            <TailcastLogo />
          </div>
          <div class="font-['Inter'] text-xl font-bold text-white">Tailcast</div>
        </div>
      </a>
    </div>
    <div>
      <div class="hidden h-full pl-12 lg:flex">
        {
          navbarLinks.map(({ href, label }) => (
            <a
              class={`relative flex h-20 cursor-pointer items-center px-4 text-2xl leading-6 font-normal text-white transition duration-200 hover:text-indigo-200 focus-visible:outline-offset-[-4px] lg:text-base lg:font-medium 2xl:px-6`}
              href={href}
              {...(isActive(href) ? { 'aria-current': 'page' } : {})}
            >
              {label}
              {isActive(href) && (
                <span class="bg-secondaryColor absolute right-0 bottom-0 left-0 h-0.5 rounded-full" />
              )}
            </a>
          ))
        }
      </div>
    </div>
    <div>
      <div class="hidden grow basis-0 justify-end lg:flex">
        <a
          class="main-border-gray bg-bgDark2 hover:bg-bgDark3 flex rounded-xl pt-2 pr-8 pb-2 pl-6 text-sm text-white"
          href="https://github.com/themewagon/tailcast"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Source code (opens in new tab)"
        >
          <GithubIcon />
          <span class="pt-px">Source code</span>
        </a>
      </div>
    </div>
    <button
      class="border-mainBorder hover:bg-bgDark2 flex cursor-pointer flex-col rounded-md border border-solid px-2 py-3 lg:hidden"
      id="mobile-menu-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <div class="mb-1 h-0.5 w-5 bg-gray-500"></div>
      <div class="mb-1 h-0.5 w-5 bg-gray-500"></div>
      <div class="h-0.5 w-5 bg-gray-500"></div>
    </button>
  </div>
  <!-- Mobile menu overlay -->
  <div class="fixed inset-0 top-20 z-40 hidden lg:hidden" id="mobile-menu-overlay"></div>
  <!-- Mobile navbar -->
  <div
    class="bg-bgDark1 border-bgDark3 absolute top-4 left-0 z-50 mt-16 hidden w-full flex-col items-center gap-10 border-y border-solid pt-10 pb-10 lg:hidden"
    id="mobile-menu"
  >
    {
      navbarLinks.map(({ label, href }) => (
        <a
          class="mobile-nav-link mr-4 ml-4 h-full cursor-pointer pt-2 text-2xl leading-6 font-normal text-white transition duration-300 hover:scale-110 lg:text-base lg:font-medium 2xl:mr-6 2xl:ml-6"
          href={href}
        >
          {label}
        </a>
      ))
    }
    <a
      class="outlined-button flex pt-2 pr-8 pb-2 pl-6"
      href="https://github.com/themewagon/tailcast"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Source code (opens in new tab)"
    >
      <GithubIcon />
      Source code
    </a>
  </div>
</nav>

<script>
  const initNavbar = () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const nav = document.getElementById('main-nav');

    const isHomepage = nav?.dataset.homepage === 'true';

    const updateNavBackground = () => {
      if (!isHomepage) return;
      if (window.scrollY > 50) {
        nav?.classList.add('bg-bgDark1/70', 'backdrop-blur-[15px]');
      } else {
        nav?.classList.remove('bg-bgDark1/70', 'backdrop-blur-[15px]');
      }
    };

    if (isHomepage) {
      updateNavBackground();
      window.addEventListener('scroll', updateNavBackground);
    }

    const openMenu = () => {
      menu?.classList.remove('hidden');
      menu?.classList.add('flex');
      overlay?.classList.remove('hidden');
      overlay?.classList.add('block');
      toggle?.setAttribute('aria-expanded', 'true');
    };

    const closeMenu = () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      overlay?.classList.add('hidden');
      overlay?.classList.remove('block');
      toggle?.setAttribute('aria-expanded', 'false');
    };

    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.contains('flex');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    overlay?.addEventListener('click', closeMenu);

    document.querySelectorAll('.mobile-nav-link').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Escape closes mobile menu
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu?.classList.contains('flex')) {
        closeMenu();
        toggle?.focus();
      }
    });

    // Focus trap in mobile menu
    menu?.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const focusable = menu.querySelectorAll<HTMLElement>('a, button');
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });
  };

  document.addEventListener('astro:page-load', initNavbar);
</script>
