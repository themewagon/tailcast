---
import FacebookIcon from '../assets/icons/FacebookIcon.astro';
import InstagramIcon from '../assets/icons/InstagramIcon.astro';
import TailcastLogo from '../assets/logos/TailcastLogo.astro';
import TwitterIcon from '../assets/icons/TwitterIcon.astro';

const footerData = [
  {
    title: 'Products',
    items: ['News and Stories', 'Roadmap', 'Integrations', 'Documentation'],
  },
  {
    title: 'Important Links',
    items: [
      'Organization Team',
      'Our Journeys',
      'Pricing Plans',
      'Roadmap',
      'Terms & Conditions',
      'Privacy Policy',
    ],
  },
  {
    title: 'Company',
    items: ['Jobs', 'Press', 'Partners', 'Community'],
  },
];
---

<footer aria-label="Site footer">
  <div class="bg-bgDark1 radius-for-skewed pt-10 pb-16 lg:pt-16 lg:pb-20">
    <div class="content-container">
      <div class="flex flex-wrap">
        <div
          class="order-1 mb-16 flex w-full flex-nowrap justify-center gap-x-8 sm:flex-wrap sm:gap-x-16 lg:order-2 lg:mb-0 lg:w-2/3 lg:justify-end"
        >
          {
            footerData.map((section, i) => (
              <div
                class:list={[
                  'text-center sm:mb-16 sm:w-auto md:mb-0 lg:text-left',
                  i === 2 ? 'hidden sm:block' : 'w-1/2 sm:w-auto',
                ]}
              >
                <h3 class="text-primaryText mb-5 text-lg font-bold">{section.title}</h3>
                <ul>
                  {section.items.map((item) => (
                    <li class="mb-3">
                      <a class="cursor-pointer text-sm text-gray-400 hover:text-gray-300" href="#">
                        {item}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
        <div class="order-2 w-full lg:order-1 lg:mb-0 lg:w-1/3">
          <div class="flex grow basis-0 items-center justify-center lg:justify-start">
            <div class="mr-2 text-6xl text-white">
              <TailcastLogo />
            </div>
            <div class="font-['Inter'] text-xl font-bold text-white">Tailcast</div>
          </div>
          <p
            class="mx-auto mt-4 mb-6 text-center leading-loose text-gray-400 sm:w-[22rem] lg:mx-0 lg:w-[20rem] lg:text-left xl:w-[24rem]"
          >
            Dashboard images were made using free Dark Admin dashboard that you can find <a
              href="#!"
              rel="noopener noreferrer"
              class="text-gray-100"
              aria-label="Dark Admin Dashboard (opens in new tab)">here.</a
            >
          </p>
          <div
            class="mb-10 flex w-full items-center justify-center gap-3 sm:w-auto lg:justify-start"
          >
            <label for="footer-email" class="sr-only">Email address</label>
            <input
              type="email"
              id="footer-email"
              placeholder="Your email address"
              class="form-input h-12 py-0 text-sm sm:!w-56 md:!w-52 xl:!w-60"
            />
            <button
              class="text-primaryText bg-primaryColor h-12 cursor-pointer rounded-xl px-5 text-sm font-semibold transition hover:bg-[#7274f3]"
              type="button"
              data-open-modal
              aria-label="Subscribe to newsletter"
            >
              Subscribe
            </button>
          </div>
          <div class="flex justify-center lg:justify-start">
            <a
              href="#"
              class="outlined-button border-mainBorderSubtle mr-2 inline-block h-10 w-10 cursor-pointer p-2 pt-[0.55rem]"
              aria-label="Facebook"
            >
              <FacebookIcon />
            </a>
            <a
              href="#"
              class="outlined-button border-mainBorderSubtle mr-2 inline-block h-10 w-10 cursor-pointer p-2 pt-[0.55rem] pl-[0.55rem]"
              aria-label="Twitter"
            >
              <TwitterIcon />
            </a>
            <a
              href="#"
              class="outlined-button border-mainBorderSubtle mr-2 inline-block h-10 w-10 cursor-pointer p-2 pt-[0.55rem] pl-[0.55rem]"
              aria-label="Instagram"
            >
              <InstagramIcon />
            </a>
          </div>
        </div>
      </div>
    </div>
    <p class="text-white text-center w-full">&copy; 2026. All right reserved by <a class="font-bold" target="_blank" href="https://github.com/matt765/">matt765</a> • Distributed by <a class="font-bold" target="_blank" href="https://themewagon.com">ThemeWagon</a></p>
  </div>
</footer>
