---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Article from '../../components/Article.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { getCollection, render } from 'astro:content';

export const getStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleData = {
  title: post.data.title,
  subtitle: post.data.description,
  date: formatDate(post.data.date),
  image: post.data.image.src,
  author: {
    name: post.data.author.name,
    role: post.data.author.role,
    avatar: post.data.author.avatar.src,
  },
  readTime: post.data.readTime,
  tags: post.data.tags,
};
---

<Layout
  title={`${post.data.title} - Tailcast`}
  description={post.data.description}
  ogType="article"
  articleMeta={{
    publishedTime: post.data.date.toISOString(),
    author: post.data.author.name,
    tags: post.data.tags,
  }}
>
  <Navbar />
  <Article articleData={articleData}>
    <Content />
  </Article>

  <!-- Related posts -->
  <section class="bg-bgDark2 pb-20">
    <div class="content-container">
      <h2 class="text-primaryText mb-8 text-2xl font-bold">See also</h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          relatedPosts.map((related) => (
            <a href={`/tailcast/blog/${related.id}`} class="group">
              <article class="card flex h-full flex-col overflow-hidden rounded-3xl transition">
                <div class="p-4">
                  <div class="bg-bgDark1Lighter flex aspect-[3/2] items-center justify-center overflow-hidden rounded-2xl">
                    <svg
                      class="text-secondaryColor/30 h-16 w-16"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="0.75"
                      viewBox="0 0 24 24"
                      set:html={related.data.icon}
                    />
                  </div>
                </div>
                <div class="flex grow flex-col px-6 pt-2 pb-8">
                  <div class="text-secondaryText mb-3 text-sm">{formatDate(related.data.date)}</div>
                  <h2 class="text-primaryText mb-3 text-xl font-bold transition group-hover:text-[#c8c9f8]">
                    {related.data.title}
                  </h2>
                  <p class="text-secondaryText text-sm leading-relaxed">{related.data.subtitle}</p>
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
  <ScrollUpButton />
</Layout>
