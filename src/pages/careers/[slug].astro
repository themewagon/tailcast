---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import CloseIcon from '../../assets/icons/CloseIcon.astro';
import { positions } from '../../content/positions';

export const getStaticPaths = () => {
  return positions.map((pos) => ({
    params: { slug: pos.slug },
    props: { position: pos },
  }));
};

const { position } = Astro.props;
---

<Layout title={`${position.title} - Careers - Tailcast`} description={position.description}>
  <Navbar />
  <section class="bg-bgDark2 pt-36 pb-20">
    <div class="content-container">
      <div class="fade-in">
        <!-- Back link -->
        <a
          href="/careers"
          class="text-secondaryText hover:text-primaryText mb-10 inline-flex items-center gap-2 transition"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M19 12H5M5 12L12 19M5 12L12 5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          Back to careers
        </a>

        <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
          <!-- Main content -->
          <div class="space-y-12 lg:col-span-2">
            <!-- Header -->
            <div>
              <div class="mb-4 flex flex-wrap items-center gap-3">
                <span class="badge-primary">{position.department}</span>
                <span class="badge-neutral">{position.location}</span>
                <span class="badge-neutral">{position.type}</span>
              </div>
              <h1 class="text-primaryText mt-6 mb-10 text-4xl font-bold lg:text-5xl">
                {position.title}
              </h1>
              <p class="text-secondaryText text-xl leading-relaxed">{position.about}</p>
            </div>
            <!-- Responsibilities -->
            <div>
              <h2 class="text-primaryText mb-6 text-2xl font-bold">What you'll do</h2>
              <ul class="space-y-4">
                {
                  position.responsibilities.map((item: string) => (
                    <li class="flex gap-3">
                      <svg
                        class="text-primaryColor mt-0.5 h-5 w-5 shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M20 6L9 17L4 12"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                      <span class="text-secondaryText leading-relaxed">{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <!-- Requirements -->
            <div>
              <h2 class="text-primaryText mb-6 text-2xl font-bold">What we're looking for</h2>
              <ul class="space-y-4">
                {
                  position.requirements.map((item: string) => (
                    <li class="flex gap-3">
                      <svg
                        class="text-primaryColor mt-0.5 h-5 w-5 shrink-0"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M20 6L9 17L4 12"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                      <span class="text-secondaryText leading-relaxed">{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <!-- Sidebar -->
          <div>
            <div class="card sticky top-28 rounded-3xl p-8">
              <h3 class="text-primaryText mb-6 text-xl font-bold">Apply for this role</h3>
              <p class="text-secondaryText mb-8 leading-relaxed">
                Interested in this position? Send us your resume and a short note about why you'd be
                a great fit.
              </p>
              <button id="open-apply-modal" class="contained-button w-full py-3 text-lg">
                Apply now
              </button>
              <div class="border-mainBorder mt-8 space-y-4 border-t pt-6">
                <div class="flex justify-between">
                  <span class="text-secondaryText text-sm">Department</span>
                  <span class="text-primaryText text-sm font-medium">{position.department}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-secondaryText text-sm">Location</span>
                  <span class="text-primaryText text-sm font-medium">{position.location}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-secondaryText text-sm">Type</span>
                  <span class="text-primaryText text-sm font-medium">{position.type}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
  <ScrollUpButton />

  <dialog id="apply-modal" class="modal-backdrop modal-fullscreen-mobile">
    <div
      class="bg-bgDark3 relative h-screen w-screen px-6 py-8 md:h-auto md:w-[33.75rem] md:rounded-2xl md:px-8"
    >
      <button class="modal-close-button" id="close-apply-modal" aria-label="Close modal">
        <CloseIcon />
      </button>
      <h2 id="apply-header" class="text-primaryText mb-1 text-xl font-bold">
        Apply for {position.title}
      </h2>
      <p id="apply-desc" class="text-secondaryText mb-6 text-sm">
        Fill in your details and we'll get back to you within a few days.
      </p>
      <form id="apply-form">
        <div class="mb-4">
          <label for="apply-name" class="text-primaryText mb-2 block font-medium">Full Name</label>
          <input
            type="text"
            id="apply-name"
            placeholder="Jane Doe"
            required
            autocomplete="off"
            class="form-input"
          />
        </div>
        <div class="mb-4">
          <label for="apply-email" class="text-primaryText mb-2 block font-medium">Email</label>
          <input
            type="email"
            id="apply-email"
            placeholder="jane@example.com"
            required
            class="form-input"
          />
        </div>
        <div class="mb-4">
          <label for="apply-portfolio" class="text-primaryText mb-2 block font-medium"
            >Portfolio / GitHub</label
          >
          <input
            type="url"
            id="apply-portfolio"
            placeholder="https://github.com/themewagon/tailcast"
            autocomplete="off"
            class="form-input"
          />
        </div>
        <div class="mb-6">
          <label for="apply-message" class="text-primaryText mb-2 block font-medium"
            >Why this role?</label
          >
          <textarea
            id="apply-message"
            rows="4"
            placeholder="Tell us briefly what excites you about this position..."
            required
            autocomplete="off"
            class="form-input resize-none"></textarea>
        </div>
        <button type="submit" class="contained-button w-full py-2.5 text-base"
          >Submit application</button
        >
      </form>
      <div
        id="apply-success"
        class="hidden flex-col items-center justify-center py-12 text-center opacity-0 transition-opacity duration-500"
      >
        <div
          class="bg-primaryColor/20 mb-5 flex h-16 w-16 items-center justify-center rounded-full"
        >
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M20 6L9 17L4 12"
              stroke="rgb(99, 102, 241)"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h3 class="text-primaryText mb-2 text-xl font-bold">Application sent!</h3>
        <p class="text-secondaryText max-w-xs leading-relaxed">
          Thanks for applying. We'll review your submission and reach out soon.
        </p>
      </div>
    </div>
  </dialog>

  <script>
    const applyModal = document.getElementById('apply-modal') as HTMLDialogElement;
    const openBtn = document.getElementById('open-apply-modal');
    const closeBtn = document.getElementById('close-apply-modal');
    const applyForm = document.getElementById('apply-form') as HTMLFormElement;
    const applySuccess = document.getElementById('apply-success');

    openBtn?.addEventListener('click', () => applyModal?.showModal());
    closeBtn?.addEventListener('click', () => applyModal?.close());
    applyModal?.addEventListener('click', (e) => {
      if (e.target === applyModal) applyModal.close();
    });

    const applyHeader = document.getElementById('apply-header');
    const applyDesc = document.getElementById('apply-desc');

    applyForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      applyForm.style.transition = 'opacity 0.3s ease';
      applyForm.style.opacity = '0';
      if (applyHeader) {
        applyHeader.style.transition = 'opacity 0.3s ease';
        applyHeader.style.opacity = '0';
      }
      if (applyDesc) {
        applyDesc.style.transition = 'opacity 0.3s ease';
        applyDesc.style.opacity = '0';
      }
      setTimeout(() => {
        applyForm.classList.add('hidden');
        applyHeader?.classList.add('hidden');
        applyDesc?.classList.add('hidden');
        applySuccess?.classList.remove('hidden');
        applySuccess?.classList.add('flex');
        requestAnimationFrame(() => {
          applySuccess?.classList.remove('opacity-0');
          applySuccess?.classList.add('opacity-100');
        });
      }, 300);
    });
  </script>
</Layout>
