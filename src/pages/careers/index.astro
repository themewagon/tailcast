---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ScrollUpButton from '../../components/ScrollUpButton.astro';
import { positions } from '../../content/positions';

const perks = [
  {
    icon: 'M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z|M2 12H22|M12 2C14.5013 4.73835 15.9228 8.29203 16 12C15.9228 15.708 14.5013 19.2616 12 22C9.49872 19.2616 8.07725 15.708 8 12C8.07725 8.29203 9.49872 4.73835 12 2Z',
    title: 'Remote-first',
    description: "Work from anywhere. We're distributed across 12 time zones and async by default.",
  },
  {
    icon: 'M12 2V22|M17 5H9.5C8.57174 5 7.6815 5.36875 7.02513 6.02513C6.36875 6.6815 6 7.57174 6 8.5C6 9.42826 6.36875 10.3185 7.02513 10.9749C7.6815 11.6313 8.57174 12 9.5 12H14.5C15.4283 12 16.3185 12.3687 16.9749 13.0251C17.6313 13.6815 18 14.5717 18 15.5C18 16.4283 17.6313 17.3185 16.9749 17.9749C16.3185 18.6313 15.4283 19 14.5 19H6',
    title: 'Competitive salary',
    description: 'Top-of-market compensation with meaningful equity for every team member.',
  },
  {
    icon: 'M20.84 4.61C20.3292 4.099 19.7228 3.69365 19.0554 3.41708C18.3879 3.14052 17.6725 2.99817 16.95 2.99817C16.2275 2.99817 15.5121 3.14052 14.8446 3.41708C14.1772 3.69365 13.5708 4.099 13.06 4.61L12 5.67L10.94 4.61C9.9083 3.57831 8.50903 2.99871 7.05 2.99871C5.59096 2.99871 4.19169 3.57831 3.16 4.61C2.1283 5.64169 1.54871 7.04097 1.54871 8.5C1.54871 9.95903 2.1283 11.3583 3.16 12.39L12 21.23L20.84 12.39C21.351 11.8792 21.7563 11.2728 22.0329 10.6054C22.3095 9.93789 22.4518 9.22249 22.4518 8.5C22.4518 7.77751 22.3095 7.0621 22.0329 6.39464C21.7563 5.72718 21.351 5.12075 20.84 4.61Z',
    title: 'Health & wellness',
    description: 'Comprehensive health insurance and $200/month wellness stipend.',
  },
  {
    icon: 'M2 3H8C9.06087 3 10.0783 3.42143 10.8284 4.17157C11.5786 4.92172 12 5.93913 12 7V21C12 20.2044 11.6839 19.4413 11.1213 18.8787C10.5587 18.3161 9.79565 18 9 18H2V3Z|M22 3H16C14.9391 3 13.9217 3.42143 13.1716 4.17157C12.4214 4.92172 12 5.93913 12 7V21C12 20.2044 12.3161 19.4413 12.8787 18.8787C13.4413 18.3161 14.2044 18 15 18H22V3Z',
    title: 'Learning budget',
    description: '$2,000/year for conferences, courses, books, and any tool that helps you grow.',
  },
  {
    icon: 'M17 3C18.3261 3 19.5979 3.52678 20.5355 4.46447C21.4732 5.40215 22 6.67392 22 8V16C22 17.3261 21.4732 18.5979 20.5355 19.5355C19.5979 20.4732 18.3261 21 17 21H7C5.67392 21 4.40215 20.4732 3.46447 19.5355C2.52678 18.5979 2 17.3261 2 16V8C2 6.67392 2.52678 5.40215 3.46447 4.46447C4.40215 3.52678 5.67392 3 7 3H17Z|M8 12H8.01|M12 12H12.01|M16 12H16.01',
    title: 'Flexible PTO',
    description: 'Unlimited time off with a 3-week minimum. We trust you to manage your schedule.',
  },
  {
    icon: 'M16 18L22 12L16 6|M8 6L2 12L8 18',
    title: 'Latest equipment',
    description: 'MacBook Pro, 4K monitor, and anything else you need to ship your best work.',
  },
];
---

<Layout
  title="Careers - Tailcast"
  description="Join the Tailcast team. We're building the future of analytics."
>
  <Navbar />
  <section class="bg-bgDark2 pt-32 pb-20 md:pt-44">
    <div class="content-container">
      <div class="fade-in">
        <!-- Open positions -->
        <div class="mb-24">
          <span class="block-subtitle">Careers</span>
          <h1 class="text-primaryText mt-6 mb-12 text-4xl font-bold lg:text-5xl">Open positions</h1>
          <div class="w-full space-y-5">
            {
              positions.map((pos) => (
                <a
                  href={`/tailcast/careers/${pos.slug}`}
                  class="card flex flex-col justify-between gap-4 p-8 hover:-translate-y-1 sm:flex-row sm:items-center"
                >
                  <div>
                    <div class="mb-2 flex items-center gap-3">
                      <h3 class="text-primaryText text-xl font-bold">{pos.title}</h3>
                      <span class="badge-primary hidden px-2 py-0.5 sm:inline">
                        {pos.department}
                      </span>
                    </div>
                    <p class="text-secondaryText">{pos.description}</p>
                  </div>
                  <div class="flex shrink-0 items-center gap-3">
                    <span class="badge-neutral bg-bgDark2 py-1.5">{pos.location}</span>
                    <span class="badge-neutral bg-bgDark2 py-1.5">{pos.type}</span>
                    <svg
                      class="text-primaryColor h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path
                        d="M5 12H19M19 12L12 5M19 12L12 19"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Hiring process -->
        <div class="mb-24">
          <h2 class="text-primaryText mb-12 text-center text-3xl font-bold">Hiring process</h2>
          <div class="relative mx-auto max-w-2xl">
            <div class="bg-mainBorder timeline-line absolute top-[2.0625rem] left-[1.375rem] w-px">
            </div>
            <div class="space-y-12">
              <div class="relative pl-20">
                <div
                  class="border-primaryColor bg-bgDark2 absolute top-[1.4375rem] left-[0.75rem] z-10 h-5 w-5 rounded-full border-2"
                >
                </div>
                <div class="text-primaryColor mb-1 text-sm font-bold">Step 1</div>
                <h3 class="text-primaryText mb-2 text-xl font-bold">Application</h3>
                <p class="text-secondaryText leading-relaxed">
                  Submit your resume and a short cover letter. We review every application within 3
                  business days.
                </p>
              </div>
              <div class="relative pl-20">
                <div
                  class="border-primaryColor bg-bgDark2 absolute top-[1.4375rem] left-[0.75rem] z-10 h-5 w-5 rounded-full border-2"
                >
                </div>
                <div class="text-primaryColor mb-1 text-sm font-bold">Step 2</div>
                <h3 class="text-primaryText mb-2 text-xl font-bold">Intro call</h3>
                <p class="text-secondaryText leading-relaxed">
                  A 30-minute video chat with our recruiter to learn about your background and share
                  more about the role.
                </p>
              </div>
              <div class="relative pl-20">
                <div
                  class="border-primaryColor bg-bgDark2 absolute top-[1.4375rem] left-[0.75rem] z-10 h-5 w-5 rounded-full border-2"
                >
                </div>
                <div class="text-primaryColor mb-1 text-sm font-bold">Step 3</div>
                <h3 class="text-primaryText mb-2 text-xl font-bold">Technical interview</h3>
                <p class="text-secondaryText leading-relaxed">
                  A practical session focused on real-world problems. No trick questions - just the
                  kind of work you'd actually do here.
                </p>
              </div>
              <div class="relative pl-20">
                <div
                  class="border-primaryColor bg-bgDark2 absolute top-[1.4375rem] left-[0.75rem] z-10 h-5 w-5 rounded-full border-2"
                >
                </div>
                <div class="text-primaryColor mb-1 text-sm font-bold">Step 4</div>
                <h3 class="text-primaryText mb-2 text-xl font-bold">Team meet</h3>
                <p class="text-secondaryText leading-relaxed">
                  Meet the people you'd work with daily. This is as much for you as it is for us -
                  culture fit goes both ways.
                </p>
              </div>
              <div class="relative pl-20" id="last-step">
                <div
                  class="border-primaryColor bg-bgDark2 absolute top-[1.4375rem] left-[0.75rem] z-10 h-5 w-5 rounded-full border-2"
                >
                </div>
                <div class="text-primaryColor mb-1 text-sm font-bold">Step 5</div>
                <h3 class="text-primaryText mb-2 text-xl font-bold">Offer</h3>
                <p class="text-secondaryText leading-relaxed">
                  If it's a match, we move fast. Expect a decision within a week of your final
                  interview.
                </p>
              </div>
            </div>
          </div>
          <script>
            const line = document.querySelector('.timeline-line') as HTMLElement;
            const lastStep = document.getElementById('last-step');
            if (line && lastStep) {
              const container = line.parentElement!;
              const containerTop = container.getBoundingClientRect().top;
              const lastStepTop = lastStep.getBoundingClientRect().top;
              const dotCenterOffset = parseFloat('1.4375') * 16 + (parseFloat('1.25') * 16) / 2;
              const height =
                lastStepTop - containerTop + dotCenterOffset - parseFloat('2.0625') * 16;
              line.style.height = `${height}px`;
            }
          </script>
        </div>

        <!-- Perks -->
        <div class="mb-24">
          <h2 class="text-primaryText mb-12 text-3xl font-bold">Why work with us</h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {
              perks.map((perk) => (
                <div class="card rounded-3xl p-8 pt-10 hover:-translate-y-1">
                  <div class="bg-primaryColor/15 mb-5 flex h-12 w-12 items-center justify-center rounded-xl">
                    <svg
                      class="text-secondaryColor h-6 w-6"
                      viewBox="0 0 24 24"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      {perk.icon.split('|').map((d: string) => (
                        <path
                          d={d}
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      ))}
                    </svg>
                  </div>
                  <h3 class="text-primaryText mb-2 text-lg font-bold">{perk.title}</h3>
                  <p class="text-secondaryText leading-relaxed">{perk.description}</p>
                </div>
              ))
            }
          </div>
        </div>

        <!-- CTA -->
        <div class="card mx-auto max-w-2xl rounded-3xl p-10 text-center lg:p-14">
          <h2 class="text-primaryText mb-4 text-2xl font-bold lg:text-3xl">Don't see your role?</h2>
          <p class="text-secondaryText mb-8 leading-relaxed">
            We're always looking for talented people. Send us your resume and tell us what you'd
            bring to the team.
          </p>
          <a href="/contact" class="contained-button mx-auto !inline-flex px-6 py-2 text-sm">
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>
  <Footer />
  <ScrollUpButton />
</Layout>
