---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollUpButton from '../components/ScrollUpButton.astro';
import { Image } from 'astro:assets';
import testimonial1 from '../assets/images/testimonial1.png';
import testimonial2 from '../assets/images/testimonial2.png';
import testimonial3 from '../assets/images/testimonial3.png';

const serviceCategories = [
  {
    id: 'tracking',
    label: 'Tracking',
    title: 'Capture every interaction',
    description:
      "Our lightweight SDK captures clicks, page views, custom events, and server-side actions with zero performance overhead. Auto-capture mode means you never miss an event - even ones you didn't know mattered yet.",
    features: [
      'Auto-capture mode',
      'Server-side & client-side SDKs',
      'Event replay & debugging',
      'Zero sampling - 100% of your data',
    ],
    icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
  },
  {
    id: 'visualization',
    label: 'Visualization',
    title: 'Dashboards that tell a story',
    description:
      'Build custom dashboards in minutes with drag-and-drop widgets. Choose from 20+ chart types, set dynamic filters, and share views with your team. Every dashboard updates in real time - no refresh needed.',
    features: [
      '20+ chart types',
      'Drag-and-drop builder',
      'Real-time updates',
      'Shareable public links',
    ],
    icon: `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>`,
  },
  {
    id: 'intelligence',
    label: 'Intelligence',
    title: 'AI that works while you sleep',
    description:
      'Automated anomaly detection catches issues before your users report them. Trend forecasting helps you plan ahead. Natural-language queries let anyone on your team ask questions and get real answers.',
    features: [
      'Anomaly detection & alerts',
      'Trend forecasting',
      'Natural-language queries',
      'Automated weekly reports',
    ],
    icon: `<path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8L12 2z"/>`,
  },
  {
    id: 'integrations',
    label: 'Integrations',
    title: 'Connects to your entire stack',
    description:
      'Native integrations with 50+ tools - from data warehouses to messaging apps. REST API and webhooks for everything else. Most teams are fully connected within a single sprint.',
    features: [
      '50+ native integrations',
      'REST API & webhooks',
      'Reverse ETL',
      'Custom connector SDK',
    ],
    icon: `<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>`,
  },
];

const comparisonFeatures = [
  {
    name: 'Real-time event streaming',
    description: 'Sub-100ms latency on all queries',
    mixpanel: false,
    amplitude: false,
    ga4: false,
  },
  {
    name: 'Unlimited event volume',
    description: 'No caps, no overage fees',
    mixpanel: false,
    amplitude: false,
    ga4: false,
  },
  {
    name: 'AI-powered insights',
    description: 'Anomaly detection & forecasting',
    mixpanel: true,
    amplitude: true,
    ga4: false,
  },
  {
    name: 'Natural-language queries',
    description: 'Ask in plain English, get answers',
    mixpanel: false,
    amplitude: false,
    ga4: false,
  },
  {
    name: 'Custom dashboards',
    description: 'Drag-and-drop builder',
    mixpanel: true,
    amplitude: true,
    ga4: false,
  },
  {
    name: 'REST API & webhooks',
    description: 'Full programmatic access',
    mixpanel: true,
    amplitude: true,
    ga4: true,
  },
  {
    name: 'Team collaboration',
    description: 'Shared views, annotations, roles',
    mixpanel: true,
    amplitude: true,
    ga4: false,
  },
  {
    name: 'Zero data sampling',
    description: '100% of events, always',
    mixpanel: false,
    amplitude: false,
    ga4: false,
  },
  {
    name: 'SOC 2 + GDPR',
    description: 'Enterprise-grade by default',
    mixpanel: true,
    amplitude: true,
    ga4: true,
  },
  {
    name: 'No per-seat pricing',
    description: 'Whole team, one price',
    mixpanel: false,
    amplitude: false,
    ga4: true,
  },
];

const process = [
  {
    step: '01',
    title: 'Connect your data',
    description:
      'Install our lightweight SDK or use the REST API. Most teams are sending events within 15 minutes.',
  },
  {
    step: '02',
    title: 'Build your views',
    description:
      'Use pre-built templates or create custom dashboards. Drag and drop metrics, set filters, choose visualizations.',
  },
  {
    step: '03',
    title: 'Get insights automatically',
    description:
      'Our AI surfaces anomalies and trends before you notice them. Set alerts that actually matter.',
  },
  {
    step: '04',
    title: 'Scale with confidence',
    description:
      'From startup to enterprise - same platform, same speed. No re-architecture needed as your data grows.',
  },
];

const testimonials = [
  {
    name: 'Marcus Rivera',
    title: 'CTO at StreamLine',
    content:
      'We cut our reporting time by 80%. Real-time dashboards replaced our weekly spreadsheet ritual.',
    image: testimonial1,
  },
  {
    name: 'Elena Lopes',
    title: 'Lead Engineer at Vertex AI',
    content:
      'The API is beautifully designed. We integrated Tailcast into our CI/CD pipeline in under an hour.',
    image: testimonial2,
  },
  {
    name: 'James Thornton',
    title: 'Product Manager at NexaFlow',
    content: 'AI alerts caught a conversion drop at 2 AM. We fixed it before the morning standup.',
    image: testimonial3,
  },
  {
    name: 'Sofia Kim',
    title: 'Head of Growth at Prism',
    content:
      'Onboarding was seamless. Our non-technical team members were creating their own dashboards within the first week.',
    image: testimonial1,
  },
  {
    name: 'David Chen',
    title: 'VP Engineering at Monolink',
    content:
      'We migrated from Mixpanel in a weekend. The data import tool handled 3 years of events without a hiccup.',
    image: testimonial2,
  },
  {
    name: 'Anna Petrova',
    title: 'Data Lead at Cosmo Health',
    content:
      'Natural-language queries changed everything. Our PMs no longer wait for the data team to pull reports.',
    image: testimonial3,
  },
];
---

<Layout
  title="Services - Tailcast"
  description="Explore Tailcast services - real-time analytics, custom dashboards, AI-powered insights, and more."
>
  <Navbar />

  <!-- 1. Tabbed Services -->
  <section class="pt-36 pb-24 lg:pt-44">
    <div class="content-container">
      <div class="services-fade">
        <div class="mb-10 text-center">
          <span class="block-subtitle mb-6 block">Our services</span>
          <h2 class="text-primaryText text-3xl font-bold tracking-tight lg:text-4xl">
            Everything your data team needs
          </h2>
        </div>

        <!-- Tab buttons -->
        <!-- Desktop tabs (4) -->
        <div class="mb-14 hidden justify-center sm:flex">
          <div
            class="bg-bgDark1/80 border-mainBorderFaintest inline-flex gap-1 rounded-2xl border p-1.5"
            role="tablist"
            aria-label="Service categories"
          >
            {
              serviceCategories.map((cat, i) => (
                <button
                  class={`tab-button relative cursor-pointer rounded-xl px-6 py-2.5 text-sm font-medium transition-all duration-300 ${i === 0 ? 'bg-bgDark3 text-primaryText shadow-lg shadow-black/20' : 'text-secondaryText hover:text-primaryText'}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-controls={`service-panel-${cat.id}`}
                  data-tab={cat.id}
                >
                  <span class="flex items-center gap-2.5">
                    <svg
                      class={`h-4 w-4 ${i === 0 ? 'text-secondaryColor' : 'text-secondaryText/50'} tab-icon transition-colors duration-300`}
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      viewBox="0 0 24 24"
                      set:html={cat.icon}
                    />
                    {cat.label}
                  </span>
                </button>
              ))
            }
          </div>
        </div>
        <!-- Mobile tabs (2 rows of 2) -->
        <div
          class="mb-14 grid grid-cols-2 gap-2 sm:hidden"
          role="tablist"
          aria-label="Service categories"
        >
          {
            serviceCategories.map((cat, i) => (
              <button
                class={`tab-button cursor-pointer rounded-xl border px-4 py-2.5 text-sm font-medium transition-colors duration-300 ${i === 0 ? 'bg-bgDark3 text-primaryText border-transparent' : 'bg-bgDark1/80 text-secondaryText hover:text-primaryText border-mainBorderFaintest'}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`service-panel-${cat.id}`}
                data-tab={cat.id}
              >
                <span class="flex items-center justify-center gap-2">
                  <svg
                    class={`h-4 w-4 ${i === 0 ? 'text-secondaryColor' : 'text-secondaryText/50'} tab-icon transition-colors duration-300`}
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    viewBox="0 0 24 24"
                    set:html={cat.icon}
                  />
                  {cat.label}
                </span>
              </button>
            ))
          }
        </div>

        <!-- Tab panels -->
        {
          serviceCategories.map((cat, i) => (
            <div
              class={`tab-panel ${i === 0 ? '' : 'hidden'}`}
              role="tabpanel"
              id={`service-panel-${cat.id}`}
              data-panel={cat.id}
            >
              <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-20">
                <div class="lg:w-1/2">
                  <div class="mb-6 flex items-center gap-4">
                    <div
                      class="flex h-12 w-12 items-center justify-center rounded-2xl"
                      style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);"
                    >
                      <svg
                        class="text-primaryColor h-6 w-6"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        viewBox="0 0 24 24"
                        set:html={cat.icon}
                      />
                    </div>
                    <h3 class="text-primaryText text-2xl font-bold">{cat.title}</h3>
                  </div>
                  <p class="text-secondaryText mb-8 leading-relaxed">{cat.description}</p>
                  <ul class="space-y-3">
                    {cat.features.map((f) => (
                      <li class="text-secondaryText flex items-center gap-3 text-sm">
                        <svg
                          class="text-primaryColor h-5 w-5 shrink-0"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          viewBox="0 0 24 24"
                        >
                          <path d="M20 6L9 17l-5-5" />
                        </svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="mt-6 lg:mt-0 lg:w-1/2">
                  <div class="bg-bgDark1Lighter flex aspect-[4/3] items-center justify-center rounded-3xl p-12 lg:p-16">
                    <svg
                      class="text-secondaryColor/15 h-32 w-32"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="0.5"
                      viewBox="0 0 24 24"
                      set:html={cat.icon}
                    />
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2. How it works -->
  <section class="py-12 lg:py-24">
    <div class="content-container">
      <div class="fade-in">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
          {
            process.map((item, i) => (
              <div class="group relative">
                {i < process.length - 1 && (
                  <div class="bg-mainBorderDarker absolute top-10 left-[calc(50%+2.5rem)] hidden h-px w-[calc(100%-3.5rem)] lg:block" />
                )}
                <div class="text-center">
                  <div
                    class="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full transition-all duration-500"
                    style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);"
                  >
                    <span class="text-secondaryColor text-2xl font-bold">{item.step}</span>
                  </div>
                  <h3 class="text-primaryText mb-3 text-lg font-bold">{item.title}</h3>
                  <p class="text-secondaryText text-sm leading-relaxed">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Comparison Table -->
  <section class="py-24">
    <div class="content-container">
      <div class="fade-in">
        <div class="mb-16 text-center">
          <span class="block-subtitle mb-6 block">Comparison</span>
          <h2 class="text-primaryText text-3xl font-bold tracking-tight lg:text-4xl">
            Why teams switch to Tailcast
          </h2>
        </div>
        <div class="bg-bgDark3/40 border-mainBorderFaintest overflow-hidden rounded-3xl border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-mainBorderDarker border-b">
                <th class="text-secondaryText w-1/2 p-3 text-left font-medium sm:p-5 lg:p-6">Feature</th>
                <th class="p-3 text-center sm:p-5 lg:p-6">
                  <span class="text-secondaryColor text-base font-bold">Tailcast</span>
                </th>
                <th class="p-3 text-center sm:p-5 lg:p-6">
                  <span class="text-secondaryText font-medium">Datawise</span>
                </th>
                <th class="hidden p-3 text-center sm:table-cell sm:p-5 lg:p-6">
                  <span class="text-secondaryText font-medium">Metrifly</span>
                </th>
                <th class="hidden p-3 text-center md:table-cell sm:p-5 lg:p-6">
                  <span class="text-secondaryText font-medium">Chartbolt</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {
                comparisonFeatures.map((f, i) => (
                  <tr
                    class={
                      i < comparisonFeatures.length - 1 ? 'border-mainBorderFaintest border-b' : ''
                    }
                  >
                    <td class="p-3 sm:p-5 lg:p-6">
                      <div class="text-primaryText text-[0.95rem] font-medium">{f.name}</div>
                      <div class="text-secondaryText mt-0.5 hidden text-sm lg:block">
                        {f.description}
                      </div>
                    </td>
                    <td class="bg-secondaryColor/[0.03] p-3 text-center sm:p-5 lg:p-6">
                      <div class="flex justify-center">
                        <div class="bg-secondaryColor/15 flex h-7 w-7 items-center justify-center rounded-lg">
                          <svg
                            class="text-secondaryColor h-4 w-4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                          >
                            <path d="M20 6L9 17l-5-5" />
                          </svg>
                          <span class="sr-only">Yes</span>
                        </div>
                      </div>
                    </td>
                    <td class="p-3 text-center sm:p-5 lg:p-6">
                      <div class="flex justify-center">
                        {f.mixpanel ? (
                          <>
                            <svg
                              class="text-secondaryText/40 h-5 w-5"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path d="M20 6L9 17l-5-5" />
                            </svg>
                            <span class="sr-only">Yes</span>
                          </>
                        ) : (
                          <>
                            <svg
                              class="h-5 w-5 text-[rgb(255_255_255/0.1)]"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path d="M5 12h14" />
                            </svg>
                            <span class="sr-only">No</span>
                          </>
                        )}
                      </div>
                    </td>
                    <td class="hidden p-3 text-center sm:table-cell sm:p-5 lg:p-6">
                      <div class="flex justify-center">
                        {f.amplitude ? (
                          <>
                            <svg
                              class="text-secondaryText/40 h-5 w-5"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path d="M20 6L9 17l-5-5" />
                            </svg>
                            <span class="sr-only">Yes</span>
                          </>
                        ) : (
                          <>
                            <svg
                              class="h-5 w-5 text-[rgb(255_255_255/0.1)]"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path d="M5 12h14" />
                            </svg>
                            <span class="sr-only">No</span>
                          </>
                        )}
                      </div>
                    </td>
                    <td class="hidden p-3 text-center md:table-cell sm:p-5 lg:p-6">
                      <div class="flex justify-center">
                        {f.ga4 ? (
                          <>
                            <svg
                              class="text-secondaryText/40 h-5 w-5"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path d="M20 6L9 17l-5-5" />
                            </svg>
                            <span class="sr-only">Yes</span>
                          </>
                        ) : (
                          <>
                            <svg
                              class="h-5 w-5 text-[rgb(255_255_255/0.1)]"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                              aria-hidden="true"
                            >
                              <path d="M5 12h14" />
                            </svg>
                            <span class="sr-only">No</span>
                          </>
                        )}
                      </div>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Testimonials -->
  <section class="py-24">
    <div class="content-container">
      <div class="fade-in">
        <div class="mb-16 text-center">
          <span class="block-subtitle mb-6 block">Testimonials</span>
          <h2 class="text-primaryText text-3xl font-bold tracking-tight lg:text-4xl">
            Trusted by data-driven teams
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            testimonials.map((t) => (
              <div class="card flex flex-col rounded-3xl p-8">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 448 512"
                  class="fill-quoteIconColor mb-4 w-6"
                >
                  <path d="M0 216C0 149.7 53.7 96 120 96h8c17.7 0 32 14.3 32 32s-14.3 32-32 32h-8c-30.9 0-56 25.1-56 56v8h64c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64H64c-35.3 0-64-28.7-64-64V320 288 216zm256 0c0-66.3 53.7-120 120-120h8c17.7 0 32 14.3 32 32s-14.3 32-32 32h-8c-30.9 0-56 25.1-56 56v8h64c35.3 0 64 28.7 64 64v64c0 35.3-28.7 64-64 64H320c-35.3 0-64-28.7-64-64V320 288 216z" />
                </svg>
                <p class="text-secondaryText mb-6 flex-grow text-sm leading-relaxed">
                  "{t.content}"
                </p>
                <div class="border-mainBorderFaintest flex items-center gap-3 border-t pt-5">
                  <Image
                    src={t.image}
                    alt={t.name}
                    width={36}
                    height={36}
                    class="rounded-full"
                    loading="eager"
                    decoding="sync"
                  />
                  <div>
                    <div class="text-primaryText text-sm font-medium">{t.name}</div>
                    <div class="text-secondaryText text-xs">{t.title}</div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-10 pb-32">
    <div class="content-container">
      <div class="fade-in">
        <div
          class="card flex flex-col items-center gap-10 rounded-3xl p-12 lg:flex-row lg:gap-16 lg:p-16"
        >
          <div class="lg:w-2/3">
            <h2 class="text-primaryText mb-4 text-3xl font-bold tracking-tight lg:text-4xl">
              Your data is already telling a story.
            </h2>
            <p class="text-secondaryText leading-relaxed">
              Most teams set up their first dashboard in under 5 minutes. No credit card required.
            </p>
          </div>
          <div class="flex w-full shrink-0 flex-col gap-3 sm:w-48 lg:ml-auto">
            <button
              data-open-modal
              class="contained-button cursor-pointer py-3 text-sm transition-all duration-300 hover:shadow-[0_0_30px_rgba(99,102,241,0.25)]"
            >
              Start free trial
            </button>
            <button data-open-modal class="outlined-button cursor-pointer py-3 text-center text-sm">
              Book a demo
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <ScrollUpButton />
</Layout>

<script>
  const initServiceTabs = () => {
    document.querySelectorAll('.tab-button').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');

        document.querySelectorAll('.tab-button').forEach((b) => {
          const isMobile = b.closest('.sm\\:hidden') !== null;
          b.classList.remove('bg-bgDark3', 'text-primaryText', 'shadow-lg', 'shadow-black/20', 'border-transparent');
          b.classList.add('text-secondaryText');
          if (isMobile) {
            b.classList.add('bg-bgDark1/80', 'border-mainBorderFaintest');
          }
          b.setAttribute('aria-selected', 'false');
          b.querySelector('.tab-icon')?.classList.remove('text-secondaryColor');
          b.querySelector('.tab-icon')?.classList.add('text-secondaryText/50');
        });
        const isMobileBtn = btn.closest('.sm\\:hidden') !== null;
        btn.classList.remove('text-secondaryText', 'bg-bgDark1/80', 'border-mainBorderFaintest');
        btn.classList.add('bg-bgDark3', 'text-primaryText', 'shadow-lg', 'shadow-black/20');
        if (isMobileBtn) {
          btn.classList.add('border-transparent');
        }
        btn.setAttribute('aria-selected', 'true');
        btn.querySelector('.tab-icon')?.classList.remove('text-secondaryText/50');
        btn.querySelector('.tab-icon')?.classList.add('text-secondaryColor');

        document.querySelectorAll('.tab-panel').forEach((panel) => {
          panel.classList.add('hidden');
        });
        const target = document.querySelector(`[data-panel="${tabId}"]`);
        target?.classList.remove('hidden');
      });
    });
  };

  document.addEventListener('astro:page-load', initServiceTabs);
</script>

<style>
  .services-fade {
    opacity: 0;
    transform: translateY(12px);
    animation: servicesFadeIn 0.8s ease forwards;
  }

  @keyframes servicesFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
